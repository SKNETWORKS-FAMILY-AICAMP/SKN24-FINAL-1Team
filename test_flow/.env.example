# OpenAI
TEST_FLOW_OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SEC=300

# Models
TEST_FLOW_LLM_MODEL_ID=gpt-4.1-mini
TEST_FLOW_OCR_MODEL_ID=gpt-4.1-mini
TEST_FLOW_STT_MODEL_ID=gpt-4o-transcribe-diarize
TEST_FLOW_EMBEDDING_PROVIDER=openai
TEST_FLOW_EMBEDDING_MODEL_ID=text-embedding-3-small
TEST_FLOW_RAG_ANSWER_PROVIDER=openai
TEST_FLOW_RAG_ANSWER_MODEL=gpt-4.1-mini
TEST_FLOW_RAG_EMBEDDING_PROVIDER=openai
TEST_FLOW_RAG_EMBEDDING_MODEL=text-embedding-3-small
# Optional. Empty means OpenAI default dimension, text-embedding-3-small = 1536.
EMBEDDING_DIMENSIONS=

# Server/job settings
STT_JOB_WORKERS=1
OCR_JOB_WORKERS=1
INTERNAL_DOCS_JOB_WORKERS=1
MINUTES_JOB_WORKERS=1

# OCR settings
OCR_MAX_PDF_PAGES=10
OCR_RENDER_SCALE=2.0
OCR_PDF_TEXT_FIRST=true
OCR_MIN_DIRECT_TEXT_CHARS=80

# RAG/Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hpm_openai_chunks
QDRANT_COLLECTION_PROJECT_MODE=true
QDRANT_COLLECTION_PREFIX=hpm_project_openai
DOC_CHUNK_CHARS=1200
DOC_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_FETCH_LIMIT=30
RAG_MAX_CONTEXT_CHARS=6000

# Parsed document ingest
LOCAL_PDF_ENABLE_TABLES=true
LOCAL_PDF_OCR_FALLBACK=true
LOCAL_PDF_MIN_PAGE_CHARS=30
PIPELINE_TIMEOUT_SEC=2400
CHUNK_SIZE=650
CHUNK_OVERLAP=120
CHUNK_VERSION=local_parent_child_650

# Django should point every AI URL to this one FastAPI server.
RUNPOD_CORE_BASE_URL=http://localhost:8500
RUNPOD_STT_BASE_URL=http://localhost:8500
RUNPOD_OCR_BASE_URL=http://localhost:8500
RUNPOD_PARSED_BASE_URL=http://localhost:8500
RAG_SERVER_URL=http://localhost:8500/chat
